# Path to the DuckDB file inside each container that mounts the shared data volume.
# dbt-runner writes to this path; api reads from it (read-only).
WAREHOUSE_PATH=/data/warehouse.duckdb

# Internal Docker-network URL the Next.js server uses to reach the API at render time.
# Never exposed to the browser — this is a server-only env var.
INTERNAL_API_URL=http://api:8000

# Optional: if host ports 3000 or 8000 are already taken, set these before `docker compose up`.
# WEB_HOST_PORT=3001
# API_HOST_PORT=8001
